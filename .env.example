DEBUG=True
SECRET_KEY=change-me-to-a-secure-random-string
ALLOWED_HOSTS=localhost,127.0.0.1
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CORS_ALLOWED_ORIGINS=http://localhost:8000

# ── Postgres / pgvector (Docker) ──────────────────────────────
DATABASE_URL=postgresql://support2thrive:support2thrive_dev_password@localhost:5432/support2thrive
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=support2thrive
POSTGRES_PASSWORD=support2thrive_dev_password
POSTGRES_DATABASE=support2thrive
POSTGRES_WORKSPACE=support2thrive_rag
POSTGRES_MAX_CONNECTIONS=10

# Obsidian vault — AI knowledge base
# Path relative to project root (e.g. ./Community brain) or absolute
OBSIDIAN_VAULT_PATH=./Community brain

# Encryption
FIELD_ENCRYPTION_KEY=your-32-byte-base64-encoded-key

# AI — Gemini 2.5 Flash
GEMINI_API_KEY=your-gemini-api-key

# ── AI Assistant ───────────────────────────────────────────────
LIGHTRAG_WORKING_DIR=./rag_storage
ASSISTANT_RATE_LIMIT_SESSION=20
ASSISTANT_RATE_LIMIT_MINUTE=5

# Email — SendGrid (transactional email for referral delivery)
# 1. Create free account at https://sendgrid.com
# 2. Settings > API Keys > Create API Key (Full Access)
# 3. Verify a sender email address in SendGrid
EMAIL_BACKEND=anymail.backends.sendgrid.EmailBackend
SENDGRID_API_KEY=SG.your-sendgrid-api-key
DEFAULT_FROM_EMAIL=noreply@yourdomain.com
SERVER_EMAIL=noreply@yourdomain.com
